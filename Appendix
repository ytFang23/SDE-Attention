def elbo_loss(recon_x, x, mu, logvar, weight=1e-2):
    MSE = F.mse_loss(recon_x, x, reduction='sum')
    KLD = -0.5 * torch.sum(1 + logvar - mu.pow(2) - logvar.exp())
    return MSE + weight * KLD
