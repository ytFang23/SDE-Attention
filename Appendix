import torch
import torch.nn as nn
from torchdiffeq import odeint_adjoint as odeint
class ODEFunc(nn.Module):
    def __init__(self, dim):
        super().__init__()         
        self.net = nn.Sequential(     
            nn.Linear(dim, 50),       
            nn.Tanh(),                
            nn.Linear(50, dim),      
            dim
        )
        for m in self.net.modules():
            if isinstance(m, nn.Linear):
                nn.init.normal_(m.weight, mean=0, std=0.1)   
                nn.init.constant_(m.bias, val=0)           
    def forward(self, t, h):
        return self.net(h)  

class ODEBlock(nn.Module):
    def __init__(self, odefunc, t0=0.0, t1=1.0, method='rk4', tol=1e-3):
        super().__init__()            
        self.odefunc = odefunc      
        self.register_buffer('t', torch.tensor([t0, t1]))
        self.method = method        
        self.tol = tol     

    def forward(self, h0):
        hT = odeint(
            self.odefunc,
            h0,
            self.t,
            rtol=self.tol,
            atol=self.tol,
            method=self.method
        )
        return hT[1]                 
\end{minted}
\end{listing}

