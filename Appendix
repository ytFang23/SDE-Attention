class NeuralODE(nn.Module):
    def __init__(self, dim):
        super().__init__()            
        self.fc_in = nn.Linear(2, dim)       
        self.odeblock = ODEBlock(ODEFunc(dim)) 
        self.fc_out = nn.Linear(dim, 2)    
        
    def forward(self, x):
        h0 = torch.relu(self.fc_in(x))      
        hT = self.odeblock(h0)               
        return self.fc_out(hT)               
